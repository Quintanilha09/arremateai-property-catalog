# =============================================================
# arremateai-property-catalog — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha os valores.
# Em desenvolvimento, os defaults do application.properties já funcionam.
# Em produção, TODAS as variáveis abaixo devem ser definidas.
# =============================================================

# --- Servidor ---
SERVER_PORT=8082

# --- Banco de Dados ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=property_catalog_db
DB_USERNAME=arremateai
DB_PASSWORD=          # OBRIGATÓRIO — sem default, deve ser definido

# --- Logging ---
LOG_LEVEL_APP=INFO
